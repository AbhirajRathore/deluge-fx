		// AMOUNT IN USD - Polished Natural Diamonds
		dataMap2 = Map();
		dataMap2.put('worksheet_id',"0#");
		dataMap2.put('content',total_usd.round(2).toString());
		dataMap2.put('row',19);
		dataMap2.put('column',7);
		dataList.add(dataMap2);
		// AMOUNT IN USD - Total
		dataMap2 = Map();
		dataMap2.put('worksheet_id',"0#");
		dataMap2.put('content',total_usd.round(2).toString());
		dataMap2.put('row',20);
		dataMap2.put('column',7);
		dataList.add(dataMap2);
		// AMOUNT IN USD - Grand Total
		dataMap2 = Map();
		dataMap2.put('worksheet_id',"0#");
		dataMap2.put('content',total_usd.round(2).toString());
		dataMap2.put('row',21);
		dataMap2.put('column',7);
		dataList.add(dataMap2);
		Amount_in_AED = 3.6725 * total_usd;
		// AMOUNT IN AED - Polished Natural Diamonds
		dataMap2 = Map();
		dataMap2.put('worksheet_id',"0#");
		dataMap2.put('content',"AED " + Amount_in_AED.round(2));
		dataMap2.put('row',19);
		dataMap2.put('column',9);
		dataList.add(dataMap2);
		// AMOUNT IN AED - Total
		dataMap2 = Map();
		dataMap2.put('worksheet_id',"0#");
		dataMap2.put('content',"AED " + Amount_in_AED.round(2));
		dataMap2.put('row',20);
		dataMap2.put('column',9);
		dataList.add(dataMap2);
		// AMOUNT IN AED - Grand Total
		dataMap2 = Map();
		dataMap2.put('worksheet_id',"0#");
		dataMap2.put('content',"AED " + Amount_in_AED.round(2));
		dataMap2.put('row',21);
		dataMap2.put('column',9);
		dataList.add(dataMap2);
		// Carat - Polished Natural Diamonds
		dataMap2 = Map();
		dataMap2.put('worksheet_id',"0#");
		dataMap2.put('content',total_carat);
		dataMap2.put('row',19);
		dataMap2.put('column',5);
