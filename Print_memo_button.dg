string button.Print_memo_button(String dis_id)
{
try 
{
	dispatch_details = zoho.crm.getRecordById("International_Disptaches",dis_id);
	Ref_No = ifNull(dispatch_details.get("Ref_No"),"");
	Ref_Date = ifNull(dispatch_details.get("Ref_Date"),"");
	Terms = ifNull(dispatch_details.get("Terms"),0);
	dis_Description = ifNull(dispatch_details.get("Description"),"");
	Account = dispatch_details.get("Account_Name").get("name");
	con_id = dispatch_details.get("Contact_Name").get("id");
	con_name = dispatch_details.get("Contact_Name").get("name");
	con_details = zoho.crm.getRecordById("Contacts",con_id);
	con_owner = con_details.get("Owner").get("name");
	Phone = ifNull(con_details.get("Phone"),"");
	Email = ifNull(con_details.get("Email"),"");
	acc_id = dispatch_details.get("Account_Name").get("id");
	acc_details = zoho.crm.getRecordById("Accounts",acc_id);
	billing_address = ifNull(dispatch_details.get("Billing_Street"),acc_details.get("factory_address"));
	shipping_address = ifNull(dispatch_details.get("Shipping_Street"),acc_details.get("factory_address"));
	Fax = ifNull(acc_details.get("Phone"),"");
	Name = dispatch_details.get("Name");
	Location = dispatch_details.get("Location");
	info Location;
	if(Location == "India")
	{
		iterations = "".leftpad(20 - 1).toList("");
		pageCounter = 1;
		numRecords = 0;
		total_of_back = 0;
		total_carat = 0;
		for each  iteration in iterations
		{
			page = pageCounter;
			perPage = 200;
			Inventory = zoho.crm.getRelatedRecords("Inventory","International_Disptaches",dis_id,page,perPage);
			if(Inventory.size() == 0)
			{
				break;
			}
			else
			{
				for each  stones in Inventory
				{
					stone_id = stones.get("Stone").get("id");
					stone_name = stones.get("Stone").get("name");
					pro = zoho.crm.getRecordById("Products",stone_id);
					carat = ifNull(pro.get("carat"),0.0);
					back_total = ifNull(pro.get("msp_total"),0.0);
					total_of_back = total_of_back + back_total;
					total_carat = total_carat + carat;
				}
			}
			pageCounter = pageCounter + 1;
			numRecords = numRecords + Inventory.size();
		}
		mp = Map();
		mp.put("quantity",numRecords);
		mp.put("total_carat",total_carat);
		mp.put("Total_Back",total_of_back);
		mp.put("Item_Name",stone_name);
		info mp;
		update_resp = zoho.crm.updateRecord("International_Disptaches",dis_id,mp);
		openUrl("https://crm.zoho.com/crm/org821143611/Template.do?step=previewPop&entityId=" + dis_id + "&module=CustomModule6&action=print&tIdx=10&relParentId=&TotalNotesCount=0&currentCount=3&model=detailPanel","new window");
		return mp + " - Print Preview is opened in a new tab";
	}
	else if(Location == "New York")
	{
		shipped_by = ifNull(dispatch_details.get("shipped_by"),"");
		if(shipped_by == "")
		{
			return "Please add Delivery Instructions";
		}
		if(Ref_Date != "")
		{
			Ref_Date = Ref_Date.toDate("dd/MMM/yy").toString("MM/dd/yyyy");
		}
