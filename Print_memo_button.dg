					stone_name = dxi_stones.get("Stone").get("name");
					color = ifNull(dxi_stones.get("Color"),"");
					if(color == "D" || color == "E" || color == "F" || color == "G" || color == "H" || color == "I" || color == "J" || color == "K" || color == "L" || color == "M" || color == "N")
					{
						RapValue = ifNull(dxi_stones.get("List_Total"),0.0).toDecimal();
						Total_Discount = ifNull(dxi_stones.get("Total_Discount"),0.0).toDecimal();
					}
					else
					{
						RapValue = ifNull(dxi_stones.get("MSP_Total"),0.0).toDecimal();
						Total_Discount = 0.0;
					}
					Net_Amount = ifNull(dxi_stones.get("Net_Amount"),0.0);
					stones = zoho.crm.getRecordById("Products",stone_id);
					Carat = ifNull(stones.get("carat"),0.0).toDecimal();
					price_per_carat = Net_Amount / Carat;
					shape = ifNull(stones.get("shape"),"");
					clarity = ifNull(stones.get("clarity"),"");
					amount = RapValue - RapValue * Total_Discount.abs() / 100;
