					dataMap1.put('Description',Description);
					dataMap1.put('Lab',lab);
					dataMap1.put('Clarity',clarity);
					dataMap1.put('Cert No',certificate_no);
					dataMap1.put('Color',color);
					dataMap1.put('Pcs',1);
					dataMap1.put('List',llist);
					dataMap1.put('Carats',Carat.toString());
					dataMap1.put('(-%)',Total_Discount.toString());
					dataMap1.put('Price',price_per_carat.round(2).toString());
					dataMap1.put('TOTAL USD',Net_Amount.round(2).toString());
					dataList.add(dataMap1);
					start_no = start_no + 1;
				}
			}
