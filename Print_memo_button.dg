		// Carat - Total
		dataMap2 = Map();
		dataMap2.put('worksheet_id',"0#");
		dataMap2.put('content',total_carat);
		dataMap2.put('row',20);
		dataMap2.put('column',5);
		dataList.add(dataMap2);
		// Split amount into integer and decimal parts
		int_part = floor(total_usd);
		dec_part = (total_usd - int_part) * 100;
		dec_part = dec_part.round(0);
		// Convert to words using toWords()
		int_words = int_part.toWords("en-us");
		amount_in_words = int_words;
		if(dec_part > 0)
		{
			dec_words = dec_part.toWords("en-us");
			amount_in_words = "US DOLLAR " + amount_in_words + " & " + dec_words + " Cents Only";
		}
		// Amount in Words
		dataMap2 = Map();
		dataMap2.put('worksheet_id',"0#");
		dataMap2.put('content',amount_in_words.toUpperCase());
		dataMap2.put('row',23);
		dataMap2.put('column',1);
		dataList.add(dataMap2);
		paramMap.put('data',dataList);
		response = invokeurl
		[
			url :"https://sheet.zoho.com/api/v2/" + resource_id
			type :POST
			parameters:paramMap
			connection:"sheet_connection"
		];
		info response;
		if(status == "failure")
		{
			return response.get("error_message");
		}
		openUrl(workbook_url,"new window");
		return "URL Opened In New Tab, Please make Sure POPUP is ON.";
	}
	else
