void automation.Test_function()
{
info "---- Contact Validation Script Started ----";
// Step 1: Fetch Deals within date range and unchecked Contact_No_Match
queryMap = Map();
queryMap.put("select_query","SELECT id, Account_Name.id, Account_Name.Parent_Account.id, Contact_Name.id, Contact_No_Match, Contact_Name.Account_Name.id " + "FROM Deals WHERE Created_Time between '2025-07-01T00:00:00+05:30' and '2025-09-30T23:59:59+05:30' and Contact_No_Match = false LIMIT 500 OFFSET 500");
response = invokeurl
[
	url :"https://www.zohoapis.com/crm/v4/coql"
	type :POST
	body:queryMap.toString()
	connection:"crm"
];
dataList = response.get("data");
info "Total Deals fetched: " + dataList.size();
noMatchCount = 0;
for each  deal in dataList
{
	try 
	{
		accountId = ifnull(deal.get("Account_Name.id"),null);
		contactId = ifnull(deal.get("Contact_Name.id"),null);
		parentAccountId = ifnull(deal.get("Account_Name.Parent_Account.id"),null);
		contactAccountId = ifnull(deal.get("Contact_Name.Account_Name.id"),null);
		// --- Step 2: Quick Skip Condition ---
		if(accountId == contactAccountId)
		{
			continue;
		}
		isContactValid = false;
		allAccountsToCheck = List();
		// --- Step 3: Identify Accounts to check (Parent + Childs) ---
		if(parentAccountId != null)
		{
			// Add parent
			allAccountsToCheck.add(parentAccountId);
			// Fetch all Child Accounts of Parent using COQL
			childQuery = Map();
			childQuery.put("select_query","SELECT id FROM Accounts WHERE Parent_Account.id = '" + parentAccountId + "'");
			childResp = invokeurl
			[
				url :"https://www.zohoapis.com/crm/v4/coql"
				type :POST
				body:childQuery.toString()
				connection:"crm"
			];
			childAccounts = ifnull(childResp.get("data"),list());
			if(childAccounts.size() > 0)
			{
				for each  child in childAccounts
				{
					allAccountsToCheck.add(child.get("id"));
				}
			}
		}
		else if(accountId != null)
		{
			// If no parent, only check same account
			allAccountsToCheck.add(accountId);
		}
		// --- Step 4: Check if the Contact belongs to any of these Accounts ---
		for each  accId in allAccountsToCheck
		{
			// Related list 1: Contacts
			contactsList = zoho.crm.getRelatedRecords("Contacts","Accounts",accId);
			for each  con in contactsList
			{
				if(con.get("id") == contactId)
				{
					isContactValid = true;
					break;
				}
			}
			if(isContactValid)
			{
				break;
			}
			// Related list 2: Associated Contacts
			assocList = zoho.crm.getRelatedRecords("Associated_Contacts11","Accounts",accId);
			for each  con in assocList
			{
				if(con.get("id") == contactId)
				{
					isContactValid = true;
					break;
				}
			}
			if(isContactValid)
			{
				break;
			}
		}
		// --- Step 5: If invalid, mark Deal as Contact_No_Match = true ---
		if(isContactValid == false)
		{
			updateMap = Map();
			updateMap.put("Contact_No_Match",true);
			updateResp = zoho.crm.updateRecord("Deals",deal.get("id"),updateMap);
			noMatchCount = noMatchCount + 1;
			// 			info "Marked No Match for Deal ID: " + deal.get("id");
		}
	}
	catch (e)
	{
		info "Error in Deal ID: " + deal.get("id") + " | " + e.toString();
	}
}
info "Total Deals marked as No Match: " + noMatchCount;
info "---- Contact Validation Script Completed ----";
