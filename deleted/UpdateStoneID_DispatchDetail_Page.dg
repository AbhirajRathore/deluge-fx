string standalone.UpdateStoneID_DispatchDetail_Page(String recordid)
{
resvp = zoho.crm.getRelatedRecords("Inventory","International_Disptaches",recordid);
StonelIst = List();
if(resvp.size() > 0)
{
	for each  rec in resvp
	{
		StroneID = rec.get("Stone").getJSON("name");
		StonelIst.add(StroneID);
	}
}
mp = Map();
mp.put("responsedata",StonelIst);
return mp;
}