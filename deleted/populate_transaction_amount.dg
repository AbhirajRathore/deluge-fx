void automation.populate_transaction_amount()
{
iterations = "".leftpad(60 - 1).toList("");
pageCounter = 1;
numRecords = 0;
createList = List();
for each  iteration in iterations
{
	page = pageCounter;
	perPage = 200;
	transactions = zoho.crm.getRecords("International_Transaction",page,perPage);
	if(transactions.size() == 0)
	{
		break;
	}
	else
	{
		for each  transaction in transactions
		{
			Amount = transaction.get("Amount");
			if(Amount == 0.0 && transaction.get("Ref_No") != null)
			{
				tran_id = transaction.get("id");
				info tran_id;
				// 				Amount = 0.0;
				// 				Total_quantity = 0;
				// 				total_carat = 0.0;
				// 				Transaction_Stones	= zoho.crm.getRelatedRecords("Inventory", "International_Transaction", tran_id);
