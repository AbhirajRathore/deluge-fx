				//                 {
				// 					for each stones in Transaction_Stones
				//                     {
				// 						Amount_USD = ifNull(stones.get("Amount_USD"),0.0);
				// 						Amount = Amount + Amount_USD;
				// 						Carat = ifNull(stones.get("Carat"),0.0);
				// 						total_carat = Carat + total_carat;
				// 					}
				// 						mp = map();
				// 						mp.put("Amount", Amount);
				// 						mp.put("total_carat", total_carat);
				// 						mp.put("quantity", Transaction_Stones.size());
				// 						mp.put("id", tran_id);
				// 						createList.add(mp);
				//                 }
			}
		}
	}
	pageCounter = pageCounter + 1;
	numRecords = numRecords + transactions.size();
}
info "Page Counter - " + pageCounter;
info "records to be updated - " + createList.size();
info "Number of records - " + numRecords;
