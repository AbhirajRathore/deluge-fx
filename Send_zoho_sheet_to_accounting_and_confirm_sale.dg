string button.Send_zoho_sheet_to_accounting_and_confirm_sale(String id)
{
resp = invokeurl
[
	url :"https://www.zohoapis.com/crm/v5/settings/variables"
	type :get
	connection:"zohocrm"
];
// info resp;
variables = resp.get("variables");
for each  variable in variables
{
	api_name = variable.get("api_name");
	if(api_name == "nivid_india_token")
	{
		nivid_india_token = variable.get("value");
	}
	else if(api_name == "nivid_india_url")
	{
		nivid_india_url = variable.get("value");
	}
}
a = invokeurl
[
	url :"https://crmsandbox.zoho.com/crm/v3/Sales_Orders/" + id
	type :GET
	connection:"crm"
];
// info a;
Owner_id = a.getJson("data").getJSON("Owner").getJSON("id");
Search_Users = zoho.crm.getRecords("users");
// info Search_Users;
users = Search_Users.get("users");
for each  user in users
{
	user_id = user.get("id");
	if(Owner_id == user_id)
	{
		user_full_name = user.get("full_name");
		Nivid_Sales_Person_Name = user.get("Nivid_Sales_Person_Name");
		info Nivid_Sales_Person_Name;
		if(Nivid_Sales_Person_Name == null)
		{
			Nivid_Sales_Person_Name = "DIRECT";
		}
	}
}
Brokerage = a.getJson("data").getJSON("Brokerage");
if(Brokerage == null)
{
	Brokerage = 0.0;
}
else
{
	Brokerage = Brokerage;
}
Broker_Name = a.getJson("data").getJSON("Broker_Name");
if(Broker_Name == null)
{
	Broker_Name = "DIRECT";
}
else
{
	Broker_Name = a.getJson("data").getJSON("Broker_Name").get("name");
}
Bank_Rate = a.getJson("data").getJSON("Bank_Rate");
if(Bank_Rate == null)
{
	return "Bank Rate Cannot be null!";
}
Account_Name = a.getJson("data").getJSON("Account_Name").getJSON("name");
info Account_Name;
Contact_Name = a.getJson("data").getJSON("Contact_Name").getJSON("name");
info Contact_Name;
Net_Amount_INR = a.getJson("data").getJSON("Net_Amount_INR");
gross_amount = a.getJson("data").getJSON("Net_Amount_USD");
info "gross_amount->" + gross_amount;
Deal_Name = a.getJson("data").getJSON("Deal_Name").get("id");
info "Deal ID - " + Deal_Name;
Deal_full_name = a.getJson("data").getJSON("Deal_Name").get("name");
Currency_Type = a.getJson("data").getJson("Currency_Type");
info "Currency_Type---->" + Currency_Type;
Payment_Details = a.getJson("data").getJson("Payment_Details");
info "Payment_Details---->" + Payment_Details;
// total_dicount = a.getJson("data").getJson("Discount");
// info "total_dicount----->" + total_dicount;
Adjustment = a.getJson("data").getJson("Adjustment");
info "Adjustment---->" + Adjustment;
Description = a.getJson("data").getJson("Description");
info "Description---->" + Description;
terms = a.getJson("data").getJson("Terms");
info "terms--->" + terms;
Term_Date = a.getJson("data").getJson("Term_Date");
//.concat("T00:00:00.000Z");
info "Term_Date--->" + Term_Date;
// create_workbook =====================================
paramMap = Map();
paramMap.put('method','workbook.createfromtemplate');
paramMap.put('resource_id','0zelo0b1a4ecfdba646a6877f6988a46d234e');
paramMap.put('workbook_name',Account_Name + " - " + today.tostring("MM-dd-yyyy"));
paramMap.put('parent_id','0zelo695ae0a474a4468ca9e00c9c3ea1f5cb');
create_workbook = invokeurl
[
	url :"https://sheet.zoho.com/api/v2/createfromtemplate"
	type :POST
	parameters:paramMap
	connection:"sheet_connection"
];
