all_accounts = List();
offset_val = 0;
more = true;
iterations = "".leftpad(50).toList("");
for each i in iterations
{
	if(more)
	{
		queryMap = Map();
		queryMap.put("select_query","SELECT id, ledger_code, Account_Name FROM Accounts WHERE Location = 'India' and ledger_code not in (' ') limit 2000 offset " + offset_val);

		response = invokeurl
		[
			url :"https://www.zohoapis.com/crm/v4/coql"
			type : POST
			body : queryMap.toString()
			connection : "crm"
		];

		records = response.get("data");
		if(records != null)
		{
			for each acc in records
			{
				all_accounts.add(acc);
			}
		}

		// pagination
		if(response.containsKey("info"))
		{
			if(response.get("info").get("more_records") == false)
			{
				more = false;
				info "No More Accounts";
				break;
			}
			else
			{
				offset_val = offset_val + 2000;
			}
		}
		else
		{
			break;
		}
	}
}
