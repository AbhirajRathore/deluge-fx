void automation.pull_out_stone_Home1111112(String account_name,String StoneIDS)
{
StoneIDS = StoneIDS.trim().toList(" ");
// info StoneIDS;
RFID = List();
serachdatalist = List();
for each  rec in StoneIDS
{
	info rec;
	if(rec.isEmpty() == false)
	{
		queryMap = Map();
		queryMap.put("select_query","select id,rfid,location,Product_Name from Products where Product_Name = '" + rec + "'");
		GetRFID = invokeurl
		[
			url :"https://www.zohoapis.com/crm/v7/coql"
			type :POST
			parameters:queryMap.toString()
			connection:"zohosandbox"
		];
		info GetRFID;
		if(GetRFID.get("data").size() > 0)
		{
			ProductDetails = GetRFID.get("data").get(0);
			// 			info ProductDetails;
			if(ProductDetails.get("rfid") != null && ProductDetails.get("location") == "DXB")
			{
				RFID.add(ProductDetails.get("rfid"));
				productmap = Map();
				productmap.put("Stone_ID",ProductDetails.get("Product_Name"));
				productmap.put("RFID",ProductDetails.get("rfid"));
				serachdatalist.add(productmap);
			}
		}
	}
}
info serachdatalist.size();
