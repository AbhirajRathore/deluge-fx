string button.Activate_marketing_account_for_sdr(String acc_id)
{
currentTimeString = zoho.currenttime.toString("yyyy-MM-dd'T'HH:mm:ss'+05:30'");
mp = Map();
mp.put("Marketing_Activated",true);
mp.put("Marketing_Activated_Date_Time",currentTimeString);
update_acc = zoho.crm.updateRecord("Accounts",acc_id,mp);
info update_acc;
return "Account is marked as Marketing Account";
}